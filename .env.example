# Safe example only. Never place credential contents in this file.
OCI_APM_AUTH_TYPE=config_file
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
OCI_REGION=ap-mumbai-1
OCI_APM_COMPARTMENT_ID=
OCI_APM_DOMAIN_ID=
OCI_APM_ALLOW_SCOPE_OVERRIDE=false
OCI_APM_ENABLE_EXPERT_QUERY=false
OCI_APM_READ_ONLY=true
OCI_APM_LOG_LEVEL=INFO
OCI_APM_CONNECT_TIMEOUT_SECONDS=10
OCI_APM_READ_TIMEOUT_SECONDS=60
